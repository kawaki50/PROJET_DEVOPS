# Build stage
FROM node:24-alpine AS builder

WORKDIR /app

# Copier les fichiers de dépendances
COPY package*.json ./

# Installer toutes les dépendances (y compris devDependencies pour Vite)
RUN npm install

# Copier le reste du code
COPY . .

# Build de l'application avec Vite
RUN npm run build

# Production stage
FROM nginx:alpine

# Copier les fichiers build vers nginx
# Vite génère dans "dist" (pas "build")
COPY --from=builder /app/dist /usr/share/nginx/html

# Configuration nginx pour SPA (Single Page Application)
RUN echo 'server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]